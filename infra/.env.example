POSTGRES_DB=proev
POSTGRES_USER=proev
# Сгенерируйте надёжный пароль, например: openssl rand -base64 24
POSTGRES_PASSWORD=change_me

# Секреты сессии для /admin — сгенерировать: openssl rand -base64 32
ADMIN_COOKIE_SECRET=change_me
ADMIN_SESSION_SECRET=change_me

# Приватный IP этого сервера в вашей внутренней сети (узнать: ip -4 addr show)
# — бэкенд открывается ТОЛЬКО на нём, чтобы NPM/другие VM в сети могли
# проксировать сюда напрямую, а из интернета порт 3001 был недоступен.
PRIVATE_BIND_IP=192.168.38.200
